{
  "name": "gestor-web-rebuild",
  "version": "1.5.0",
  "description": "Gestor de perfiles web aislados reconstruido desde cero",
  "main": "main.js",
  "author": "Gestor Web",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "check": "node scripts/check-js.js",
    "test": "node scripts/run-tests.js",
    "test:ipc": "playwright test --config=playwright.config.js",
    "qa": "npm run check && npm test",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "local.gestorweb.rebuild",
    "productName": "Gestor Web",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "styles.css",
      "main.js",
      "preload.js",
      "profile-browser.html",
      "profile-browser.css",
      "profile-browser.js",
      "profile-browser-preload.js",
      "build/icon.png",
      "package.json",
      "src/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Gestor-Web-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "@playwright/test": "^1.44.0"
  }
}
