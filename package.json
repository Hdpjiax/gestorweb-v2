{
  "name": "gestor-web-rebuild",
  "version": "1.3.0",
  "description": "Gestor de perfiles web aislados reconstruido desde cero",
  "main": "main.js",
  "author": "Gestor Web",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check app.js",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "local.gestorweb.rebuild",
    "productName": "Gestor Web",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "main.js",
      "preload.js",
      "package.json",
      "src/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
