<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/bg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
        <TextView android:id="@+id/editorTitle" style="@style/PageTitle" android:text="Nuevo perfil"/>
        <EditText android:id="@+id/editName" style="@style/ProfileInput" android:hint="Nombre"/><EditText android:id="@+id/editUrl" style="@style/ProfileInput" android:hint="URL inicial"/><EditText android:id="@+id/editGroup" style="@style/ProfileInput" android:hint="Grupo"/>
        <TextView style="@style/SectionTitle" android:text="Proxy"/><Spinner android:id="@+id/editProxyType" style="@style/DarkSpinner"/><EditText android:id="@+id/editProxy" style="@style/ProfileInput" android:hint="host:puerto"/><EditText android:id="@+id/editProxyUser" style="@style/ProfileInput" android:hint="Usuario"/><EditText android:id="@+id/editProxyPass" style="@style/ProfileInput" android:hint="Contraseña" android:inputType="textPassword"/>
        <TextView style="@style/SectionTitle" android:text="Fingerprint coherente con Android"/><Spinner android:id="@+id/editTemplate" style="@style/DarkSpinner"/><Spinner android:id="@+id/editSpoofLevel" style="@style/DarkSpinner"/><EditText android:id="@+id/editUserAgent" style="@style/ProfileInput" android:hint="User-Agent (vacío = plantilla)"/><EditText android:id="@+id/editTimezone" style="@style/ProfileInput" android:hint="Timezone, ej. America/Mexico_City"/><EditText android:id="@+id/editResolution" style="@style/ProfileInput" android:hint="Resolución, ej. 1080x2400"/>
        <TextView style="@style/SectionTitle" android:text="Preset de privacidad"/><Spinner android:id="@+id/editPrivacyPreset" style="@style/DarkSpinner"/>
        <androidx.appcompat.widget.SwitchCompat android:id="@+id/editBlockTrackers" style="@style/FlagSwitch" android:text="Bloquear trackers (~80 dominios)"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editStripTracking" style="@style/FlagSwitch" android:text="Quitar UTM/fbclid/gclid"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editSanitizeHeaders" style="@style/FlagSwitch" android:text="Reducir client hints"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editNoReferrer" style="@style/FlagSwitch" android:text="No-referrer"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editWebrtc" style="@style/FlagSwitch" android:text="Bloquear WebRTC"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editDoh" style="@style/FlagSwitch" android:text="DNS privado / DoH solicitado"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editForceHttps" style="@style/FlagSwitch" android:text="Force HTTPS"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editHarden" style="@style/FlagSwitch" android:text="Spoof fuerte"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editMemory" style="@style/FlagSwitch" android:text="Solo en memoria"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editAutoWipe" style="@style/FlagSwitch" android:text="Auto-wipe al cerrar"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editTor" style="@style/FlagSwitch" android:text="Tor mediante Orbot (externo)"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editHar" style="@style/FlagSwitch" android:text="Registrar solicitudes (HAR básico)"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editAntiLeak" style="@style/FlagSwitch" android:text="Anti-leak"/><androidx.appcompat.widget.SwitchCompat android:id="@+id/editCompat" style="@style/FlagSwitch" android:text="Modo compatibilidad"/>
        <EditText android:id="@+id/editNotes" style="@style/ProfileInput" android:hint="Notas" android:minLines="3" android:gravity="top"/>
        <Button android:id="@+id/saveProfile" style="@style/PrimaryButton" android:text="GUARDAR PERFIL"/><Button android:id="@+id/cancelProfile" style="@style/GhostButton" android:text="CANCELAR"/>
    </LinearLayout>
</ScrollView>
