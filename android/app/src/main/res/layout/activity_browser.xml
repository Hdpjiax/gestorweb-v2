<?xml version="1.0" encoding="utf-8"?>
<!-- Browser screen: title bar + progress + chrome toolbar + WebView -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gw_bg">

    <!-- ── Title bar / profile header ── -->
    <LinearLayout
        android:id="@+id/browserTitleBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/titlebar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_3"
        android:paddingEnd="@dimen/space_3"
        android:background="@drawable/bg_titlebar">

        <!-- Back to dashboard -->
        <Button
            android:id="@+id/btnCloseBrowser"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="14sp"
            android:textColor="@color/gw_text_secondary"
            android:background="?android:selectableItemBackgroundBorderless"
            android:gravity="center"
            android:padding="0dp" />

        <!-- Profile name + mode -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/space_2">

            <TextView
                android:id="@+id/tvBrowserProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/gw_text"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvBrowserProfileMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/gw_muted" />
        </LinearLayout>

        <!-- Mode pill -->
        <TextView
            android:id="@+id/tvBrowserModePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_pill_accent" />
    </LinearLayout>

    <!-- ── Page load progress bar (2dp, accent blue) ── -->
    <ProgressBar
        android:id="@+id/browserProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:max="100"
        android:progress="0"
        android:visibility="gone"
        android:progressDrawable="@drawable/bg_progress" />

    <!-- ── Chrome toolbar (back / forward / refresh / address / more) ── -->
    <LinearLayout
        android:id="@+id/browserToolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_2"
        android:paddingEnd="@dimen/space_2"
        android:background="@color/gw_panel">

        <!-- Back -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="@string/btn_back"
            style="@style/GW.NavButton"
            android:alpha="0.4" />

        <!-- Forward -->
        <Button
            android:id="@+id/btnForward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="@string/btn_forward"
            android:layout_marginStart="@dimen/space_1"
            style="@style/GW.NavButton"
            android:alpha="0.4" />

        <!-- Address bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_2"
            android:layout_marginEnd="@dimen/space_2"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/space_3"
            android:paddingEnd="@dimen/space_3"
            android:background="@drawable/bg_input">

            <!-- Security icon -->
            <TextView
                android:id="@+id/tvSecurityIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_secure"
                android:textSize="12sp"
                android:layout_marginEnd="@dimen/space_2" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="@string/hint_address_bar"
                android:textColorHint="@color/gw_muted"
                android:textColor="@color/gw_text"
                android:textSize="@dimen/text_sm"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:background="@null"
                android:selectAllOnFocus="true" />
        </LinearLayout>

        <!-- Refresh -->
        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="@string/btn_refresh"
            style="@style/GW.NavButton" />

        <!-- More options -->
        <Button
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="@string/btn_more"
            android:layout_marginStart="@dimen/space_1"
            style="@style/GW.NavButton" />
    </LinearLayout>

    <!-- ── WebView ── -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
