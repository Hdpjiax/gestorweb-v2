<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:orientation="vertical" android:padding="14dp" android:background="@drawable/bg_panel">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
        <TextView android:id="@+id/profileName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/text" android:textSize="19sp" android:textStyle="bold"/>
        <TextView android:id="@+id/profilePreset" android:layout_width="wrap_content" android:layout_height="wrap_content" android:padding="6dp" android:textColor="@color/accent_2" android:textStyle="bold"/>
    </LinearLayout>
    <TextView android:id="@+id/profileMeta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:textColor="@color/muted"/>
    <ProgressBar android:id="@+id/privacyScore" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="10dp" android:max="100" android:progressDrawable="@drawable/bg_progress"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/openProfile" style="@style/PrimaryButton" android:layout_width="0dp" android:layout_weight="1" android:text="ABRIR"/>
        <Button android:id="@+id/editProfile" style="@style/GhostButton" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="EDITAR"/>
        <Button android:id="@+id/deleteProfile" style="@style/GhostButton" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="BORRAR"/>
    </LinearLayout>
</LinearLayout>
