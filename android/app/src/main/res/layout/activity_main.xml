<?xml version="1.0" encoding="utf-8"?>
<!-- Main dashboard: sidebar rail + content area (Windows 11 shell style) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gw_bg">

    <!-- ── Title bar ── -->
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/titlebar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/space_3"
        android:paddingEnd="@dimen/space_4"
        android:background="@drawable/bg_titlebar">

        <!-- App icon placeholder (replace with ic_launcher 24dp) -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="GW"
            android:textSize="11sp"
            android:textColor="@color/gw_accent"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_pill_accent" />

        <TextView
            android:id="@+id/tvTitleBarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_3"
            android:text="@string/titlebar_dashboard"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/gw_text"
            android:textStyle="bold" />

        <!-- License status pill -->
        <TextView
            android:id="@+id/tvLicensePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pill_online"
            android:textSize="10sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_pill_success" />
    </LinearLayout>

    <!-- ── Body: sidebar + content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ── Sidebar rail ── -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="@dimen/sidebar_width"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="@dimen/space_3"
            android:paddingBottom="@dimen/space_3"
            android:background="@drawable/bg_sidebar">

            <!-- Dashboard nav item -->
            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_nav_item_active">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⊞"
                    android:textSize="20sp"
                    android:textColor="@color/gw_accent" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_dashboard"
                    android:textSize="8sp"
                    android:textColor="@color/gw_accent" />
            </LinearLayout>

            <!-- Profiles nav item -->
            <LinearLayout
                android:id="@+id/navProfiles"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp"
                android:background="?android:selectableItemBackgroundBorderless">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☰"
                    android:textSize="20sp"
                    android:textColor="@color/gw_text_secondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_profiles"
                    android:textSize="8sp"
                    android:textColor="@color/gw_text_secondary" />
            </LinearLayout>

            <!-- License nav item -->
            <LinearLayout
                android:id="@+id/navLicense"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="4dp"
                android:background="?android:selectableItemBackgroundBorderless">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑"
                    android:textSize="18sp"
                    android:textColor="@color/gw_text_secondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_license"
                    android:textSize="8sp"
                    android:textColor="@color/gw_text_secondary" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Settings at bottom -->
            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?android:selectableItemBackgroundBorderless">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙"
                    android:textSize="20sp"
                    android:textColor="@color/gw_muted" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_settings"
                    android:textSize="8sp"
                    android:textColor="@color/gw_muted" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Content area ── -->
        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/contentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <!-- ── Page header ── -->
                <TextView
                    android:id="@+id/tvPageBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dashboard_brand"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/gw_accent_2"
                    android:textStyle="bold"
                    android:letterSpacing="0.18"
                    android:textAllCaps="true" />

                <View android:layout_width="match_parent" android:layout_height="4dp" />

                <TextView
                    android:id="@+id/tvPageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dashboard_title"
                    android:textSize="@dimen/text_2xl"
                    android:textColor="@color/gw_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPageDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dashboard_desc"
                    android:textSize="@dimen/text_sm"
                    android:textColor="@color/gw_muted"
                    android:layout_marginTop="4dp" />

                <View android:layout_width="match_parent" android:layout_height="@dimen/space_4" />

                <!-- ── Stats row ── -->
                <LinearLayout
                    android:id="@+id/statsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/statProfiles"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/space_2"
                        android:orientation="vertical"
                        android:padding="@dimen/space_4"
                        android:background="@drawable/bg_card">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_stat_profiles"
                            style="@style/GW.SectionLabel" />
                        <View android:layout_width="match_parent" android:layout_height="4dp" />
                        <TextView
                            android:id="@+id/tvStatProfilesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_2xl"
                            android:textColor="@color/gw_text"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/statProxy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:padding="@dimen/space_4"
                        android:background="@drawable/bg_card">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_stat_proxy"
                            style="@style/GW.SectionLabel" />
                        <View android:layout_width="match_parent" android:layout_height="4dp" />
                        <TextView
                            android:id="@+id/tvStatProxyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_2xl"
                            android:textColor="@color/gw_text"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── License card ── -->
                <LinearLayout
                    android:id="@+id/cardLicense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4"
                    android:background="@drawable/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_license_active"
                            android:textSize="@dimen/text_lg"
                            android:textColor="@color/gw_text"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvLicenseStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/pill_online"
                            android:textSize="10sp"
                            android:textColor="#FFFFFFFF"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:background="@drawable/bg_pill_success" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="6dp" />

                    <TextView
                        android:id="@+id/tvHwid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_xs"
                        android:textColor="@color/gw_muted"
                        android:fontFamily="monospace" />

                    <View android:layout_width="match_parent" android:layout_height="8dp" />

                    <Button
                        android:id="@+id/btnCopyHwid"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:text="@string/btn_copy_hwid"
                        style="@style/GW.Button.Ghost" />
                </LinearLayout>

                <!-- ── New profile card ── -->
                <LinearLayout
                    android:id="@+id/cardNewProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4"
                    android:background="@drawable/bg_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_new_profile"
                        android:textSize="@dimen/text_xl"
                        android:textColor="@color/gw_text"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_new_profile_desc"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/gw_muted" />

                    <EditText
                        android:id="@+id/etProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_3"
                        android:hint="@string/hint_profile_name"
                        style="@style/GW.Input" />

                    <EditText
                        android:id="@+id/etProfileUrl"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_2"
                        android:hint="@string/hint_profile_url"
                        android:inputType="textUri"
                        style="@style/GW.Input" />

                    <EditText
                        android:id="@+id/etProfileProxy"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_2"
                        android:hint="@string/hint_profile_proxy"
                        style="@style/GW.Input" />

                    <EditText
                        android:id="@+id/etProfileUa"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_2"
                        android:hint="@string/hint_profile_ua"
                        style="@style/GW.Input" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_3"
                        android:text="@string/label_mode"
                        style="@style/GW.SectionLabel" />

                    <Spinner
                        android:id="@+id/spinnerMode"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="@dimen/space_2"
                        android:background="@drawable/bg_input"
                        android:paddingStart="@dimen/space_4"
                        android:paddingEnd="@dimen/space_4" />

                    <Button
                        android:id="@+id/btnCreateProfile"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginTop="@dimen/space_3"
                        android:text="@string/btn_create_profile"
                        style="@style/GW.Button.Primary" />
                </LinearLayout>

                <!-- ── Saved profiles card ── -->
                <LinearLayout
                    android:id="@+id/cardProfiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4"
                    android:background="@drawable/bg_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_profiles_title"
                        android:textSize="@dimen/text_xl"
                        android:textColor="@color/gw_text"
                        android:textStyle="bold" />

                    <!-- Profile list (populated programmatically) -->
                    <LinearLayout
                        android:id="@+id/profileList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/space_3" />

                    <!-- Empty state -->
                    <TextView
                        android:id="@+id/tvProfilesEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_profiles_empty"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/gw_muted"
                        android:gravity="center"
                        android:paddingTop="@dimen/space_6"
                        android:paddingBottom="@dimen/space_6"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- ── Info / deactivate card ── -->
                <LinearLayout
                    android:id="@+id/cardInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_3"
                    android:orientation="vertical"
                    android:padding="@dimen/space_4"
                    android:background="@drawable/bg_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_android_limits_title"
                        android:textSize="@dimen/text_xl"
                        android:textColor="@color/gw_text"
                        android:textStyle="bold" />

                    <View android:layout_width="match_parent" android:layout_height="@dimen/space_3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_android_limits_1"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/gw_muted" />

                    <View android:layout_width="match_parent" android:layout_height="@dimen/space_2" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_android_limits_2"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/gw_muted" />

                    <Button
                        android:id="@+id/btnDeactivate"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/btn_deactivate"
                        style="@style/GW.Button.Ghost" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="@dimen/space_6" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
