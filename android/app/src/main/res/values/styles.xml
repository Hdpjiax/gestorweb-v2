<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gw_accent</item>
        <item name="colorPrimaryDark">@color/gw_bg</item>
        <item name="colorAccent">@color/gw_accent</item>
        <item name="android:windowBackground">@color/gw_bg</item>
        <item name="android:textColor">@color/gw_text</item>
    </style>

    <!-- Menu row item -->
    <style name="MenuRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Menu icon (emoji/font text icon) -->
    <style name="MenuIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Menu label -->
    <style name="MenuLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">@color/gw_text</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- App-specific styles -->
    <style name="GW" />

    <style name="GW.SectionLabel">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/gw_accent_2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="GW.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/gw_accent</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="GW.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/gw_accent</item>
        <item name="rippleColor">@color/gw_accent_surface</item>
    </style>

    <style name="GW.NavButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textColor">@color/gw_text</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="GW.Input">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/input_height</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingStart">@dimen/space_3</item>
        <item name="android:paddingEnd">@dimen/space_3</item>
        <item name="android:textColor">@color/gw_text</item>
        <item name="android:textColorHint">@color/gw_muted</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>
</resources>
