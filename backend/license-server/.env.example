# Modo servidor propio opcional
PORT=8787
LICENSE_ADMIN_TOKEN=cambia_este_token_largo
PUBLIC_LICENSE_SERVER_URL=http://127.0.0.1:8787
DB_FILE=./licenses-db.json
DATABASE_URL=
DATABASE_SSL=true
NODE_ENV=development

# Claves de firma. La privada solo se usa en tu PC/admin, nunca en la app del cliente.
PRIVATE_KEY_FILE=./private_key.pem
PUBLIC_KEY_FILE=./public_key.pem

# Modo recomendado sin VPS/dominio: Supabase DB-only
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=tu_anon_publishable_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_solo_admin

# Para la app Electron en desarrollo si no quieres meter estos datos dentro del payload:
# GW_LICENSE_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
# GW_LICENSE_SUPABASE_ANON_KEY=tu_anon_publishable_key
# GW_LICENSE_PUBLIC_KEY_FILE=/ruta/absoluta/public_key.pem
